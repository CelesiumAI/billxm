{
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }
      ]
    }
  ],
  "functions": {
    "api/analyze.js": { "maxDuration": 300 },
    "api/gate.js": { "maxDuration": 10 },
    "api/checkout.js": { "maxDuration": 10 },
    "api/webhook.js": { "maxDuration": 10 }
  }
}
